generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WordStatus {
  NEW
  HARD
  EASY
}

model Word {
  id          String       @id @default(cuid())
  term        String       @unique
  definition  String?
  example     String?
  translation String?
  status      WordStatus   @default(NEW)
  lastSeenAt  DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  reviews     WordReview[]
}

model WordReview {
  id          String     @id @default(cuid())
  wordId      String
  wasCorrect  Boolean
  statusAfter WordStatus
  createdAt   DateTime   @default(now())

  word Word @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@index([wordId, createdAt])
}

model InterviewQA {
  id             String   @id @default(cuid())
  question       String
  answer         String?
  timesAnswered  Int      @default(0)
  timesCorrect   Int      @default(0)
  timesIncorrect Int      @default(0)
  timesShown     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model WordTrainingStats {
  id           Int      @id @default(autoincrement())
  accuracy     Float
  accuracy100  Float    @default(0)
  totalAnswers Int
  totalWords   Int
  createdAt    DateTime @default(now())
}

model RecapTrainingStats {
  id        Int      @id @default(autoincrement())
  score     Int
  coverage  Float
  structure Float
  language  Float
  fluency   Float
  createdAt DateTime @default(now())
}

model FluencySkill {
  id               Int               @id @default(autoincrement())
  name             String            @unique
  evaluationPrompt String
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  fluencyQuestions FluencyQuestion[]
}

model FluencyQuestion {
  id         Int      @id @default(autoincrement())
  text       String
  skillId    Int
  timesShown Int      @default(0)
  createdAt  DateTime @default(now())

  skill FluencySkill @relation(fields: [skillId], references: [id], onDelete: Cascade)
}

model FluencyAnswer {
  id        Int      @id @default(autoincrement())
  questionId Int
  skillId    Int
  isCorrect  Boolean
  speechDurationMs Int
  reactionDelayMs    Int
  answer String
  createdAt DateTime @default(now())
}

model DailySections {
  id         Int      @id @default(autoincrement())
  name       String
  sectionKey String   @unique
  orderIndex Int
  autoEnd    Boolean  @default(false)
  target     Json
}

model DailyCompleted {
  id                 Int      @id @default(autoincrement())
  date               String @db.VarChar(10) // Format: YYYY-MM-DD
  sectionKey         String
  stats              Json
  startedAt          DateTime
  endedAt            DateTime
  completedInSeconds Int
}

model RecapTopic {
  id        Int      @id @default(autoincrement())
  text      String
  createdAt DateTime @default(now())
}